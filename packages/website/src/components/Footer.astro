<footer class="bg-[#111111] text-white border-t-[3px] border-black mt-20">
  <div class="section-container py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 font-display font-bold text-xl mb-4">
          <span class="bg-[#FFE500] text-[#111111] px-2 py-1 border-[3px] border-white">AI</span>
          <span>Adaptasi</span>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed">
          Helping businesses integrate AI and automation to scale operations efficiently.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="font-display font-bold text-sm uppercase tracking-wide mb-4 text-[#FFE500]">Navigation</h4>
        <ul class="space-y-2">
          <li><a href="/" class="text-gray-400 hover:text-white transition-colors text-sm">Home</a></li>
          <li><a href="/services" class="text-gray-400 hover:text-white transition-colors text-sm">Services</a></li>
          <li><a href="/portfolio" class="text-gray-400 hover:text-white transition-colors text-sm">Portfolio</a></li>
          <li><a href="/about" class="text-gray-400 hover:text-white transition-colors text-sm">About</a></li>
          <li><a href="/contact" class="text-gray-400 hover:text-white transition-colors text-sm">Contact</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-display font-bold text-sm uppercase tracking-wide mb-4 text-[#FFE500]">Contact</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li>Indonesia</li>
          <li>contact@adaptasiai.id</li>
        </ul>
      </div>
    </div>

    <div class="border-t-[3px] border-gray-800 mt-8 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-xs">
        &copy; {new Date().getFullYear()} Adaptasi AI. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <span class="bg-[#FFE500] text-[#111111] px-2 py-1 border-[3px] border-white font-mono text-xs font-bold">
          n8n partner
