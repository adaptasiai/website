---
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
---

<NavBar />

<main class="pt-16">
  <Section background="yellow" class="!py-20 md:!py-28">
    <div class="max-w-3xl">
      <div class="inline-block bg-black text-white px-3 py-1 border-[3px] border-black font-mono text-xs font-bold mb-6">
        GET IN TOUCH
      </div>
      <h1 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl leading-tight mb-6">
        Contact Us
      </h1>
      <p class="text-lg md:text-xl text-[#111111]/80 max-w-2xl">
        Have a project in mind? Let's discuss how we can help your business grow with AI and automation.
      </p>
    </div>
  </Section>

  <Section background="white">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div>
        <h2 class="font-display font-bold text-2xl mb-6">Send Us a Message</h2>
        <form id="contact-form" class="space-y-6">
          <div>
            <label for="name" class="block font-display font-bold text-sm uppercase tracking-wide mb-2">
              Name <span class="text-[#FF6B9D]">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="neo-input"
              placeholder="Your name"
            />
          </div>

          <div>
            <label for="email" class="block font-display font-bold text-sm uppercase tracking-wide mb-2">
              Email <span class="text-[#FF6B9D]">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="neo-input"
              placeholder="you@company.com"
            />
          </div>

          <div>
            <label for="company" class="block font-display font-bold text-sm uppercase tracking-wide mb-2">
              Company
            </label>
            <input
              type="text"
              id="company"
              name="company"
              class="neo-input"
              placeholder="Your company name"
            />
          </div>

          <div>
            <label for="budget" class="block font-display font-bold text-sm uppercase tracking-wide mb-2">
              Project Budget
            </label>
            <select id="budget" name="budget" class="neo-input">
              <option value="">Select budget range</option>
              <option value="under-5m">Under Rp 5.000.000</option>
              <option value="5-15m">Rp 5.000.000 - Rp 15.000.000</option>
              <option value="15-30m">Rp 15.000.000 - Rp 30.000.000</option>
              <option value="above-30m">Above Rp 30.000.000</option>
              <option value="enterprise">Enterprise (custom)</option>
            </select>
          </div>

          <div>
            <label for="message" class="block font-display font-bold text-sm uppercase tracking-wide mb-2">
              Message <span class="text-[#FF6B9D]">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="neo-input resize-none"
              placeholder="Tell us about your project..."
            ></textarea>
          </div>

          <Button type="submit" variant="primary" size="lg" class="w-full">
            Send Message →
          </Button>
        </form>

        <div id="form-success" class="hidden neo-card p-8 bg-[#A8FF00] border-green-500">
          <h3 class="font-display font-bold text-xl mb-2">Message Sent! 🎉</h3>
          <p class="text-[#111111]/80">
            Thank you for reaching out. We'll get back to you within 24-48 hours.
          </p>
        </div>
      </div>

      <div class="space-y-8">
        <div class="neo-card p-6">
          <h3 class="font-display font-bold text-xl mb-4">Contact Info</h3>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 bg-[#FFE500] border-[3px] border-black flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </div>
              <div>
                <p class="font-display font-bold text-sm">Email</p>
                <a href="mailto:contact@adaptasiai.id" class="text-[#666666] hover:text-[#111111] transition-colors">
                  contact@adaptasiai.id
                </a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 bg-[#FF6B9D] border-[3px] border-black flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <div>
                <p class="font-display font-bold text-sm">Location</p>
                <p class="text-[#666666]">Indonesia</p>
              </div>
            </div>
          </div>
        </div>

        <div class="neo-card p-6 bg-[#111111] text-white">
          <h3 class="font-display font-bold text-xl mb-4 text-white">Quick Response</h3>
          <p class="text-gray-400 text-sm mb-4">
            We typically respond within 24-48 hours. For urgent matters, feel free to reach out directly.
          </p>
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 bg-[#A8FF00] border-[2px] border-white animate-pulse"></span>
            <span class="font-mono text-sm">Usually responds within a day</span>
          </div>
        </div>

        <div class="neo-card p-6">
          <h3 class="font-display font-bold text-xl mb-4">What Happens Next</h3>
          <ol class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 bg-[#FFE500] border-[3px] border-black flex items-center justify-center font-mono text-xs font-bold flex-shrink-0">1</span>
              <span class="text-[#666666] text-sm">We review your message and project details</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 bg-[#00C2FF] border-[3px] border-black flex items-center justify-center font-mono text-xs font-bold flex-shrink-0">2</span>
              <span class="text-[#666666] text-sm">Schedule a free consultation call</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 bg-[#A8FF00] border-[3px] border-black flex items-center justify-center font-mono text-xs font-bold flex-shrink-0">3</span>
              <span class="text-[#666666] text-sm">Receive a detailed proposal and quote</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 bg-[#FF6B9D] border-[3px] border-black flex items-center justify-center font-mono text-xs font-bold flex-shrink-0">4</span>
              <span class="text-[#666666] text-sm">Start building your solution</span>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </Section>
</main>

<Footer />

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMessage = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // In a real implementation, this would send to a backend or service
    // For now, just show success
    form.classList.add('hidden');
    if (successMessage) {
      successMessage.classList.remove('hidden');
    }
  });
</script>