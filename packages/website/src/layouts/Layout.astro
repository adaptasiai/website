---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Helping businesses integrate AI and automation to scale operations efficiently." } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Adaptasi AI</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#FAFAFA] font-body text-[#111111] antialiased">
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #FFE500;
    --color-accent: #FF6B9D;
    --color-secondary: #00C2FF;
    --color-accent2: #A8FF00;
    --color-bg: #FAFAFA;
    --color-surface: #FFFFFF;
    --color-border: #000000;
    --color-text: #111111;
    --color-muted: #666666;

    --shadow-neubrutalism: 4px 4px 0px #000;
    --shadow-neubrutalism-hover: 6px 6px 0px #000;

    --border-width: 3px;
    --radius: 0px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
  }

  .font-display {
    font-family: 'Space Grotesk', sans-serif;
  }

  .font-body {
    font-family: 'Inter', sans-serif;
  }

  .font-mono {
    font-family: 'JetBrains Mono', monospace;
  }

  .neo-card {
    background: var(--color-surface);
    border: var(--border-width) solid var(--color-border);
    box-shadow: var(--shadow-neubrutalism);
    transition: all 150ms ease-out;
  }

  .neo-card:hover {
    box-shadow: var(--shadow-neubrutalism-hover);
    transform: translate(-2px, -2px);
  }

  .neo-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    border: var(--border-width) solid var(--color-border);
    box-shadow: var(--shadow-neubrutalism);
    transition: all 150ms ease-out;
    cursor: pointer;
  }

  .neo-btn:hover {
    box-shadow: var(--shadow-neubrutalism-hover);
    transform: translate(-2px, -2px);
  }

  .neo-btn:active {
    box-shadow: 2px 2px 0px #000;
    transform: translate(2px, 2px);
  }

  .neo-btn-primary {
    background: var(--color-primary);
    color: var(--color-text);
  }

  .neo-btn-secondary {
    background: var(--color-surface);
    color: var(--color-text);
  }

  .neo-btn-outline {
    background: transparent;
    color: var(--color-text);
  }

  .neo-input {
    width: 100%;
    border: var(--border-width) solid var(--color-border);
    background: var(--color-surface);
    padding: 0.75rem 1rem;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    transition: all 150ms ease-out;
  }

  .neo-input:focus {
    outline: none;
    box-shadow: var(--shadow-neubrutalism);
  }

  .neo-input::placeholder {
    color: var(--color-muted);
  }

  .section-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 768px) {
    .section-container {
      padding: 0 2rem;
    }
  }
</style>